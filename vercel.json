{
  "buildCommand": "yarn --cwd ./excalidraw-app build",
  "outputDirectory": "excalidraw-app/build",
  "installCommand": "yarn install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "origin"
        },
        {
          "key": "Feature-Policy",
          "value": "*"
        }
      ]
    },
    {
      "source": "/:file*.woff2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(Virgil|Cascadia|Assistant-Regular).woff2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|fonts|locales|android-chrome|apple-touch|favicon|manifest|service-worker|robots|screenshots|landing).*)",
      "destination": "/index.html"
    }
  ]
}
